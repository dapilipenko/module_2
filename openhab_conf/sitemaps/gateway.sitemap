sitemap gateway label="Gateway" {
    Frame label="Environment" {
        Text item=Gateway_Temperature
        Text item=Gateway_Humidity
    }
    Frame label="Lighting" {
        Switch item=Gateway_Light
        Slider item=Gateway_Dimmer
    }
    Frame label="Health" {
        Text item=Gateway_Battery
        Text item=Gateway_LQI
    }
}
