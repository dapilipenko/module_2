sitemap analytics label="Multi-Sensor Analytics"
{
  Frame label="System Status" {
    Text item=Analytics_Status
    Text item=Analytics_SampleCount
    Text item=Analytics_LastCalculation
  }

  Frame label="Virtual Sensors" {
    Text item=Sensor_OutdoorTemperature
    Text item=Sensor_IndoorTemperature
    Text item=Sensor_OutdoorHumidity
    Text item=Sensor_IndoorHumidity
    Text item=Sensor_BarometricPressure
    Text item=Sensor_CO2
    Text item=Sensor_Daylight
  }

  Frame label="Sensor Charts (24h)" {
    Chart item=Sensor_OutdoorTemperature period=D refresh=60000
    Chart item=Sensor_BarometricPressure period=D refresh=60000
    Chart item=Sensor_CO2 period=D refresh=60000
    Chart item=Sensor_Daylight period=D refresh=60000
  }

  Frame label="Statistical Metrics" {
    Text item=Analytics_OutdoorTemperature_SMA15
    Text item=Analytics_OutdoorTemperature_EMA30
    Text item=Analytics_OutdoorTemperature_StdDev
    Text item=Analytics_OutdoorTemperature_Min60
    Text item=Analytics_OutdoorTemperature_Max60
    Text item=Analytics_OutdoorTemperature_P90
    Text item=Analytics_BarometricPressure_SMA15
    Text item=Analytics_BarometricPressure_EMA30
    Text item=Analytics_BarometricPressure_StdDev
    Text item=Analytics_BarometricPressure_Min60
    Text item=Analytics_BarometricPressure_Max60
    Text item=Analytics_CO2_P95
  }

  Frame label="Correlation Analysis" {
    Text item=Analytics_Correlation_OutdoorIndoorTemp
    Text item=Analytics_CorrelationBand_OutdoorIndoorTemp label="Outdoor vs Indoor Temperature Band [MAP(correlation-band.map):%s]"
    Text item=Analytics_Correlation_OutdoorTempOutdoorHumidity
    Text item=Analytics_CorrelationBand_OutdoorTempOutdoorHumidity label="Outdoor Temperature vs Outdoor Humidity Band [MAP(correlation-band.map):%s]"
    Text item=Analytics_Correlation_PressureOutdoorHumidity
    Text item=Analytics_CorrelationBand_PressureOutdoorHumidity label="Pressure vs Outdoor Humidity Band [MAP(correlation-band.map):%s]"
    Text item=Analytics_Correlation_DaylightOutdoorTemp
    Text item=Analytics_CorrelationBand_DaylightOutdoorTemp label="Daylight vs Outdoor Temperature Band [MAP(correlation-band.map):%s]"
    Text item=Analytics_Correlation_CO2IndoorHumidity
    Text item=Analytics_CorrelationBand_CO2IndoorHumidity label="CO2 vs Indoor Humidity Band [MAP(correlation-band.map):%s]"
    Text item=Analytics_LeadLag_OutdoorIndoorTemp
    Text item=Analytics_Causality_OutdoorIndoorTemp
    Text item=Analytics_LeadLag_DaylightOutdoorTemp
    Text item=Analytics_Causality_DaylightOutdoorTemp
  }

  Frame label="Correlation Matrix" {
    Text item=Analytics_CorrelationMatrix_Header
    Text item=Analytics_CorrelationMatrix_OutdoorTemperature
    Text item=Analytics_CorrelationMatrix_IndoorTemperature
    Text item=Analytics_CorrelationMatrix_OutdoorHumidity
    Text item=Analytics_CorrelationMatrix_IndoorHumidity
    Text item=Analytics_CorrelationMatrix_BarometricPressure
    Text item=Analytics_CorrelationMatrix_CO2
    Text item=Analytics_CorrelationMatrix_Daylight
  }

  Frame label="Trend Detection" {
    Text item=Analytics_OutdoorTemperature_Slope
    Text item=Analytics_OutdoorTemperature_TrendDirection label="Outdoor Temperature Trend [MAP(trend.map):%s]"
    Text item=Analytics_OutdoorTemperature_ChangePoint label="Outdoor Temperature Change Point [MAP(trend.map):%s]"
    Text item=Analytics_OutdoorTemperature_Forecast60m
    Text item=Analytics_BarometricPressure_Slope
    Text item=Analytics_BarometricPressure_TrendDirection label="Barometric Pressure Trend [MAP(trend.map):%s]"
    Text item=Analytics_BarometricPressure_ChangePoint label="Barometric Pressure Change Point [MAP(trend.map):%s]"
    Text item=Analytics_BarometricPressure_Forecast60m
  }
}
